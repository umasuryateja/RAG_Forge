# -----------------------------------------------------------------------------
# Enterprise AI Knowledge Assistant - Environment Configuration Template
# Copy this file to '.env' and populate your local credentials.
# -----------------------------------------------------------------------------

# API Configuration
PROJECT_NAME="Enterprise AI Knowledge Assistant"
API_V1_STR="/api/v1"

# CORS Configurations (Comma separated list of allowed origin hosts)
BACKEND_CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# Relational Database Connection Settings
# SQLite local fallback: sqlite:///./sql_app.db
# PostgreSQL production template: postgresql://username:password@localhost:5432/rag_db
DATABASE_URL="sqlite:///./sql_app.db"

# Google Gemini API Settings (Obtain key from Google AI Studio)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"

# Embedding Model Setup (all-MiniLM-L6-v2 runs locally on CPU/GPU)
EMBEDDING_MODEL_NAME="all-MiniLM-L6-v2"

# Vector Database Setup (ChromaDB persistence paths)
CHROMA_DB_PATH="chroma_db"
CHROMA_COLLECTION_NAME="documents"

# RAG Splitting Guidelines
UPLOAD_DIR="uploads"
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# Logging Configurations
# Standard python log levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="INFO"
LOG_FILE="logs/app.log"
